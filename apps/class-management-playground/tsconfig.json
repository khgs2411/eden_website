{
	"compilerOptions": {
		"target": "es2023",
		"lib": ["ES2023", "DOM"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"types": ["vite/client"],
		"paths": {
			"@eden/class-management-react": ["../../packages/class-management-react/src/index.ts"]
		}
	},
	"include": ["src", "vite.config.ts"]
}
