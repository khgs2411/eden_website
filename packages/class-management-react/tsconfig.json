{
	"compilerOptions": {
		"target": "es2023",
		"lib": ["ES2023", "DOM"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"declaration": true,
		"emitDeclarationOnly": false,
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src"]
}
